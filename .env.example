# ==================== 服务器配置 ====================
NODE_ENV=development
PORT=3000

# ==================== OpenClaw 集成 ====================
OPENCLAW_URL=http://localhost:18789
OPENCLAW_API_KEY=your_openclaw_api_key_here

# ==================== Binance API ====================
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
BINANCE_TESTNET=false

# ==================== 其他交易所 API (可选) ====================
OKX_API_KEY=your_okx_api_key_here
OKX_API_SECRET=your_okx_api_secret_here
OKX_PASSPHRASE=your_okx_passphrase_here

BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here

# ==================== 链上数据 API ====================
# Whale Alert
WHALE_ALERT_API_KEY=your_whale_alert_api_key_here

# Etherscan
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# DEX Screener
DEX_SCREENER_API_KEY=your_dex_screener_api_key_here

# ==================== 社交 API ====================
# Twitter (需要通过 OpenTwitter MCP)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# ==================== 数据库配置 (可选) ====================
DATABASE_URL=postgresql://user:password@localhost:5432/cryptoflow

# ==================== Redis (可选) ====================
REDIS_URL=redis://localhost:6379

# ==================== 加密密钥 ====================
# 用于加密存储敏感信息
ENCRYPTION_KEY=your_32_char_encryption_key_here

# ==================== NextAuth ====================
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000
